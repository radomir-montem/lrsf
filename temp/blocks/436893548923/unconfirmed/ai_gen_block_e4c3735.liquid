    {
      "type": "header",
      "content": "Selected name"
    },
    {
      "type": "checkbox",
      "id": "show_selected_name",
      "label": "Show selected color name",
      "default": true
    },
    {
      "type": "range",
      "id": "selected_name_size",
      "label": "Name size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "selected_name_color",
      "label": "Name color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "selected_name_spacing",
      "label": "Name spacing",
      "min": 0,
      "max": 30,
